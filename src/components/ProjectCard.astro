---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data, id } = project;
---

<a href={`/portfolio/${id}`} class="group block">
  <div class="overflow-hidden bg-cream-deep">
    <Image
      src={data.coverImage}
      alt={data.title}
      widths={[400, 800, 1200]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
      class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-105"
    />
  </div>
  <p class="mt-3 text-xs tracking-widest uppercase text-bark-soft">
    {data.category}
  </p>
  <h3 class="font-serif text-2xl leading-snug">{data.title}</h3>
</a>
