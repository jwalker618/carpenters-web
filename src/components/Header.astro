---
import { Image } from 'astro:assets';
import { site, nav } from '../site';
import badgeCream from '../assets/brand/badge-cream.png';
import badgeNavy from '../assets/brand/badge-navy.png';

const igUrl = `https://instagram.com/${site.instagramHandle}`;
---

<header class="nav" id="site-nav">
  <a class="brand" href="#top" aria-label={`${site.name} — home`}>
    <span class="cmark">
      <!-- cream badge over the hero; crossfades to navy when the nav solidifies -->
      <Image class="cm-cyan" src={badgeCream} alt="" widths={[40, 80]} />
      <Image class="cm-navy" src={badgeNavy} alt="" widths={[40, 80]} />
    </span>
    <span class="bt"><b>AVM</b><small>Timber Design</small></span>
  </a>

  <nav class="navlinks">
    {nav.map((item) => <a class="ulink" href={item.href}>{item.label}</a>)}
    <a class="ig" href={igUrl} target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <rect x="3" y="3" width="18" height="18" rx="5"></rect>
        <circle cx="12" cy="12" r="4"></circle>
        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
      </svg>
      Instagram
    </a>
  </nav>

  <button class="menu-btn" id="menuBtn" aria-label="Open menu">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
      <line x1="3" y1="7" x2="21" y2="7"></line>
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="17" x2="21" y2="17"></line>
    </svg>
  </button>
</header>

<span id="top"></span>

<!-- Mobile menu sheet -->
<div class="sheet" id="sheet">
  <div class="sheet-top">
    <Image src={badgeCream} alt="" widths={[34, 68]} />
    <button id="sheetClose" aria-label="Close menu">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
        <line x1="5" y1="5" x2="19" y2="19"></line>
        <line x1="19" y1="5" x2="5" y2="19"></line>
      </svg>
    </button>
  </div>
  <nav>
    {nav.map((item) => <a href={item.href} data-close>{item.label}</a>)}
    <a href="#contact" data-close>Enquire <em>↗</em></a>
  </nav>
  <div class="sheet-foot">@{site.instagramHandle} · {site.email}</div>
</div>
