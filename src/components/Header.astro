---
import { site, nav } from '../site';

interface Props {
  /** If true, the header starts transparent (over a dark hero) and
      solidifies once the page is scrolled. Default is solid. */
  transparent?: boolean;
}

const { transparent = false } = Astro.props;

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header
  id="site-header"
  data-transparent={String(transparent)}
  class:list={[
    'site-nav fixed inset-x-0 top-0 z-40',
    transparent ? 'is-transparent' : 'is-solid',
  ]}
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-5">
    <!-- Brand: emblem + tracked wordmark, mirroring the invoice mark -->
    <a href="/" class="flex items-center gap-3" aria-label={site.name}>
      <svg
        class="h-9 w-9 shrink-0 sm:h-10 sm:w-10"
        viewBox="0 0 64 64"
        aria-hidden="true"
      >
        <circle cx="32" cy="32" r="32" fill="#0F2138"></circle>
        <g
          stroke="#80C8D8"
          stroke-width="1.2"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M14 32 Q32 22 50 32 Q32 42 14 32 Z"></path>
          <line x1="19" y1="24" x2="19" y2="18"></line>
          <line x1="24" y1="22" x2="24" y2="14"></line>
          <line x1="29" y1="21" x2="29" y2="12"></line>
          <line x1="35" y1="21" x2="35" y2="12"></line>
          <line x1="40" y1="22" x2="40" y2="14"></line>
          <line x1="45" y1="24" x2="45" y2="18"></line>
          <path d="M27 42 L27 47 L33 47"></path>
          <path d="M37 42 L37 49"></path>
        </g>
        <circle
          cx="32"
          cy="32"
          r="4.5"
          fill="none"
          stroke="#80C8D8"
          stroke-width="1.2"></circle>
        <circle cx="32" cy="32" r="1.6" fill="#80C8D8"></circle>
      </svg>
      <span class="leading-tight">
        <span
          class="block text-[11px] font-light tracking-[0.24em] sm:text-xs"
          >AVM TIMBER DESIGN</span
        >
        <span
          class="mt-0.5 block text-[9px] font-light tracking-[0.32em] opacity-60 sm:text-[10px]"
          >LONDON</span
        >
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden gap-8 text-xs tracking-[0.18em] uppercase md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'transition-opacity hover:opacity-100',
              isActive(item.href)
                ? 'opacity-100 underline underline-offset-8'
                : 'opacity-70',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
        <line x1="3" y1="7" x2="21" y2="7"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="17" x2="21" y2="17"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile nav: always solid so links stay readable over any background -->
  <nav
    id="mobile-nav"
    class="hidden border-t border-cream-deep bg-cream text-bark md:hidden"
  >
    <div class="mx-auto flex max-w-6xl flex-col px-5 py-2">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'py-3 text-xs tracking-[0.18em] uppercase',
              isActive(item.href) ? 'text-bark' : 'text-bark-soft',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const toggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const open = mobileNav?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });

  if (header.dataset.transparent === 'true') {
    const update = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 40);
    };
    update();
    document.addEventListener('scroll', update, { passive: true });
  }
</script>
