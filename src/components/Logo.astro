---
/* Anne's brand seal — vectorised from the supplied artwork.
   Renders inline so `fill="currentColor"` picks up the parent
   element's text colour. Pass Tailwind sizing/colour classes via
   the `class` prop; the SVG fills the container. */
import logoSvg from '../assets/logo.svg?raw';

interface Props {
  class?: string;
  ariaLabel?: string;
}

const { class: className = '', ariaLabel } = Astro.props;
---

<div
  class:list={[className]}
  role={ariaLabel ? 'img' : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : 'true'}
  set:html={logoSvg}
/>
