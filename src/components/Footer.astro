---
import { site } from '../site';

const socials = Object.entries(site.social).filter(([, url]) => url);
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-cream-deep bg-cream-deep/40">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-12 sm:flex-row sm:justify-between"
  >
    <div>
      <p class="font-serif text-xl">{site.name}</p>
      <p class="mt-1 text-sm text-bark-soft">{site.workshopLocation}</p>
    </div>

    <div class="text-sm text-bark-soft">
      <a href={`mailto:${site.email}`} class="block hover:text-forest"
        >{site.email}</a
      >
      <a href={`tel:${site.phone}`} class="block hover:text-forest"
        >{site.phone}</a
      >
      {
        socials.length > 0 && (
          <div class="mt-2 flex gap-4">
            {socials.map(([name, url]) => (
              <a href={url} class="capitalize hover:text-forest">
                {name}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-5 pb-8 text-xs text-bark-soft">
    &copy; {year} {site.carpenterName}. All work shown is original.
  </div>
</footer>
