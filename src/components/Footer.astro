---
import { Image } from 'astro:assets';
import { site } from '../site';
import badgeCream from '../assets/brand/badge-cream.png';

const year = new Date().getFullYear();
---

<!-- Slim footer. Contact details live only in the Contact section above,
     so they're deliberately not repeated here. -->
<footer class="foot">
  <div class="foot-in shell pad">
    <div class="fbrand">
      <Image src={badgeCream} alt="" widths={[38, 76]} />
      <div>
        <span class="wordmark">{site.name}</span>
        <small>Bespoke joinery · North London</small>
      </div>
    </div>
    <span class="foot-legal">
      © {year} {site.carpenterName} · Over thirty years at the bench · trained IBTC Lowestoft
    </span>
  </div>
</footer>
