---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../site';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = site.tagline } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : `${site.name} — Bespoke Joinery, London`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Spline+Sans+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Nav solidify + scroll reveals, driven by a single rAF poll so they
      // work even when 'scroll' events are throttled. The nav goes solid
      // once past ~72% of the first viewport (i.e. off the hero).
      const nav = document.getElementById('site-nav');
      const reveals = Array.from(document.querySelectorAll('.reveal'));
      const update = () => {
        const y = window.scrollY || document.documentElement.scrollTop || 0;
        const vh = window.innerHeight || document.documentElement.clientHeight;
        nav?.classList.toggle('solid', y > vh * 0.72);
        for (const el of reveals) {
          if (el.classList.contains('in')) continue;
          if (el.getBoundingClientRect().top < vh * 0.92) el.classList.add('in');
        }
      };
      let lastY = -1;
      const loop = () => {
        const y = window.scrollY || 0;
        if (y !== lastY) {
          lastY = y;
          update();
        }
        requestAnimationFrame(loop);
      };
      update();
      loop();
      addEventListener('resize', update);
      // safety: never leave content hidden if something stalls
      setTimeout(() => reveals.forEach((el) => el.classList.add('in')), 1800);

      // Mobile menu sheet
      const sheet = document.getElementById('sheet');
      document
        .getElementById('menuBtn')
        ?.addEventListener('click', () => sheet?.classList.add('open'));
      document
        .getElementById('sheetClose')
        ?.addEventListener('click', () => sheet?.classList.remove('open'));
      sheet
        ?.querySelectorAll('[data-close]')
        .forEach((a) => a.addEventListener('click', () => sheet.classList.remove('open')));
    </script>
  </body>
</html>
