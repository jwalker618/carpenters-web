---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../site';

interface Props {
  title?: string;
  description?: string;
  /** Home uses this so the nav can float over the hero. */
  transparentNav?: boolean;
}

const {
  title,
  description = site.tagline,
  transparentNav = false,
} = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : site.name;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,200..500;1,300..400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header transparent={transparentNav} />
    <main class:list={['flex-1', transparentNav ? '' : 'pt-20']}>
      <slot />
    </main>
    <Footer />

    <script>
      // Reveal `.fade-in` elements when they scroll into view.
      const reveal = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              reveal.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
      );
      document
        .querySelectorAll('.fade-in')
        .forEach((el) => reveal.observe(el));

      // Hero parallax: scrolls the image up at a fraction of scroll speed.
      const parallaxEl = document.querySelector<HTMLElement>('[data-parallax]');
      if (
        parallaxEl &&
        !matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        const speed = parseFloat(parallaxEl.dataset.parallax || '0.35');
        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            parallaxEl.style.transform = `translate3d(0, ${window.scrollY * speed}px, 0) scale(1.15)`;
            ticking = false;
          });
        };
        parallaxEl.style.transform = 'translate3d(0, 0, 0) scale(1.15)';
        parallaxEl.style.willChange = 'transform';
        document.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>
