---
import BaseLayout from '../layouts/BaseLayout.astro';
import Logo from '../components/Logo.astro';
import { site } from '../site';

const socials = Object.entries(site.social).filter(([, url]) => url);
---

<BaseLayout title="Contact">
  <section class="mx-auto max-w-5xl px-5 py-16">
    <!-- Letterhead: Anne's seal at the top of the page, so getting in
         touch feels like writing onto his stationery. -->
    <Logo class="mb-14 h-56 w-56 sm:h-64 sm:w-64" />

    <h1 class="font-serif text-4xl italic sm:text-5xl">Get in touch.</h1>
    <p class="mt-2 max-w-xl text-bark-soft">
      Tell me about the piece you have in mind, or just say hello. I read
      every message myself.
    </p>

    <div class="mt-12 grid gap-12 md:grid-cols-[1fr_280px]">
      <!-- Contact form (powered by Web3Forms) -->
      <form id="contact-form" class="space-y-5">
        <!--
          Web3Forms access key. Get a free one at https://web3forms.com
          (just enter your email — no account needed) and paste it into
          src/site.ts. Until then the form will not deliver messages.
        -->
        <input
          type="hidden"
          name="access_key"
          value={site.web3formsAccessKey}
        />
        <input type="hidden" name="subject" value={`New enquiry — ${site.name}`} />
        <!-- Honeypot field to catch spam bots; real people leave it blank. -->
        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          tabindex="-1"
          autocomplete="off"
        />

        <div>
          <label for="name" class="block text-sm tracking-wide text-bark-soft">
            Name
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="mt-1 w-full border border-cream-deep bg-white px-3 py-2 outline-none focus:border-forest"
          />
        </div>

        <div>
          <label for="email" class="block text-sm tracking-wide text-bark-soft">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="mt-1 w-full border border-cream-deep bg-white px-3 py-2 outline-none focus:border-forest"
          />
        </div>

        <div>
          <label
            for="message"
            class="block text-sm tracking-wide text-bark-soft"
          >
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            class="mt-1 w-full border border-cream-deep bg-white px-3 py-2 outline-none focus:border-forest"
          ></textarea>
        </div>

        <button
          type="submit"
          class="border border-forest bg-forest px-8 py-3 text-sm tracking-widest text-cream uppercase transition-colors hover:bg-forest-deep"
        >
          Send message
        </button>

        <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
      </form>

      <!-- Direct contact details -->
      <aside class="space-y-6 text-sm md:border-l md:border-cream-deep md:pl-8">
        <div>
          <h2 class="text-xs tracking-widest text-bark-soft uppercase">
            Email
          </h2>
          <a
            href={`mailto:${site.email}`}
            class="mt-1 block font-serif text-xl hover:text-forest">{site.email}</a
          >
        </div>
        <div>
          <h2 class="text-xs tracking-widest text-bark-soft uppercase">
            Phone
          </h2>
          <a
            href={`tel:${site.phone}`}
            class="mt-1 block font-serif text-xl hover:text-forest">{site.phone}</a
          >
        </div>
        <div>
          <h2 class="text-xs tracking-widest text-bark-soft uppercase">
            Workshop
          </h2>
          <address class="mt-1 font-serif text-xl not-italic leading-snug">
            {
              site.addressLines.map((line) => <span class="block">{line}</span>)
            }
          </address>
        </div>
        {
          socials.length > 0 && (
            <div class="flex gap-4 pt-2">
              {socials.map(([name, url]) => (
                <a href={url} class="capitalize hover:text-forest">
                  {name}
                </a>
              ))}
            </div>
          )
        }
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = 'Sending…';
    status.className = 'text-sm text-bark-soft';

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: new FormData(form),
      });
      const result = await response.json();
      if (response.ok && result.success) {
        status.textContent = 'Thanks — your message is on its way.';
        status.className = 'text-sm text-forest';
        form.reset();
      } else {
        status.textContent =
          result.message || 'Something went wrong. Please email instead.';
        status.className = 'text-sm text-red-700';
      }
    } catch {
      status.textContent =
        'Could not send right now. Please email me directly.';
      status.className = 'text-sm text-red-700';
    }
  });
</script>
