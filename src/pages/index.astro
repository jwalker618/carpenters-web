---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Gallery from '../components/Gallery.astro';
import { site } from '../site';
import heroImg from '../assets/work/IMG_6086.JPEG';
import compass from '../assets/brand/compass-cyan.png';
import qr from '../assets/brand/avm-qr.jpg';

const igUrl = `https://instagram.com/${site.instagramHandle}`;
---

<BaseLayout>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <Image
      src={heroImg}
      alt="Oak-slatted kitchen island with marble worktop"
      widths={[768, 1280, 1920, 2400]}
      sizes="100vw"
      loading="eager"
    />
    <div class="hero-in shell pad">
      <span class="eyebrow">Bespoke joinery · North London</span>
      <h1>The patience of a <em>master craftsman</em>, brought to the rooms you live in.</h1>
      <div class="hero-meta">
        <span>Kitchens</span><span class="dot"></span>
        <span>Wardrobes</span><span class="dot"></span>
        <span>Built-ins &amp; furniture</span><span class="dot"></span>
        <span>By appointment</span>
      </div>
    </div>
    <div class="scrollcue">Scroll</div>
  </section>

  <!-- ===================== INTRO ===================== -->
  <section class="intro shell pad">
    <h2 class="reveal">
      Furniture and fitted joinery, made to be enjoyed for <em>generations.</em>
    </h2>
    <div class="aside reveal">
      <span class="eyebrow">The studio</span>
      <p>
        Over thirty years working with wood — from the construction of classic
        yachts to bespoke interiors across London.
      </p>
      <p>
        Every commission begins with a conversation: how a piece will be lived
        with, how it should sit naturally within a space, and the atmosphere it
        should create.
      </p>
    </div>
  </section>

  <!-- ===================== WORK ===================== -->
  <section class="work shell pad" id="work">
    <div class="shead reveal">
      <h2>Selected work</h2>
      <p class="meta">An ongoing record of finished pieces — newest first.</p>
    </div>
    <Gallery featureMatch="IMG_2387" exclude={['IMG_6086']} />
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="services shell pad" id="services">
    <div class="shead reveal">
      <h2>A collection of things I'd happily make for you</h2>
      <p class="meta">Designed collaboratively · made to measure</p>
    </div>

    <div class="svc-grid">
      <article class="svc reveal">
        <span class="n">01</span>
        <h3>Cabinetry &amp; Built-Ins</h3>
        <p>
          Custom kitchens, wardrobes, bathroom furniture and fitted cabinetry —
          thoughtfully designed to feel integrated, refined and timeless,
          combining practicality with the character of finely made furniture.
        </p>
      </article>
      <article class="svc reveal">
        <span class="n">02</span>
        <h3>Tables &amp; Seating</h3>
        <p>
          Bespoke dining benches and occasional tables designed around the
          proportions of your space and the way you live. Functional, enduring
          pieces made for everyday use.
        </p>
      </article>
      <article class="svc reveal">
        <span class="n">03</span>
        <h3>Bespoke Commissions</h3>
        <p>
          Individually designed furniture and interior joinery, from standalone
          pieces to complete room installations. Every commission is developed
          collaboratively — work that is both functional and deeply personal.
        </p>
      </article>
    </div>

    <div class="detail-row">
      <div class="detail reveal">
        <h4><span class="eyebrow">Craft</span>Bespoke Joinery</h4>
        <p>
          High-quality joinery crafted to stand the test of time. From
          shaker-style doors and custom drawers to handles and finishing
          details, each element is made to measure with precision workmanship.
        </p>
      </div>
      <div class="detail reveal">
        <h4><span class="eyebrow">Palette</span>Materials</h4>
        <p>
          Wood veneers, bespoke CNC-cut MDF, melamine, reclaimed timber and
          composite products — achieving both contemporary and traditional
          finishes to the highest standard.
        </p>
      </div>
      <div class="detail reveal">
        <h4><span class="eyebrow">Surface</span>Finishes</h4>
        <p>
          Spray paint, oil and clear lacquer, applied in collaboration with
          specialist finishers. Every finish is carefully selected to complement
          your space and design vision.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section class="process" id="process">
    <Image class="watermark" src={compass} alt="" widths={[220, 420]} />
    <div class="process-in shell pad">
      <div class="shead reveal">
        <h2>How a piece <em>comes to be</em></h2>
        <p class="meta">From first conversation to final installation</p>
      </div>
      <div class="steps">
        <div class="step reveal">
          <span class="k">01</span><h3>Consultation</h3>
          <p>
            We begin with a discussion about your ideas, requirements and how the
            piece will function within the space — understanding the style,
            practicality and aesthetic you're after.
          </p>
        </div>
        <div class="step reveal">
          <span class="k">02</span><h3>Concept Design</h3>
          <p>
            We prepare initial sketches and design concepts, then refine the
            design with you until you are completely satisfied before moving
            forward.
          </p>
        </div>
        <div class="step reveal">
          <span class="k">03</span><h3>Materials &amp; Estimate</h3>
          <p>
            We select materials together — carcass interiors, wood grains,
            finishes and hardware — then provide a fixed quotation and clear
            timeline before production begins.
          </p>
        </div>
        <div class="step reveal">
          <span class="k">04</span><h3>Production</h3>
          <p>
            Each component is precision cut, crafted and assembled within the
            workshop to ensure the highest standards of quality and efficiency
            prior to installation.
          </p>
        </div>
        <div class="step reveal">
          <span class="k">05</span><h3>Installation</h3>
          <p>
            Your completed joinery is carefully delivered and professionally
            installed with attention to every detail — a seamless finish, and
            complete satisfaction.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== ABOUT ===================== -->
  <section class="about shell pad" id="about">
    <div class="col-media">
      <!-- No portrait of Anne yet: clearly-marked placeholder slot.
           Replace with <Image> of a workshop photo when supplied. -->
      <div class="ph reveal"><span>portrait — Anne in the workshop</span></div>
    </div>
    <div class="reveal">
      <span class="eyebrow">About Anne</span>
      <h2>From Amsterdam furniture making to classic yachts — and into your <em>home.</em></h2>
      <div class="body">
        <p>
          Anne van Mansvelt has been working with wood for over thirty years.
          After studying furniture making in Amsterdam, he moved to the UK to
          train in traditional wooden boat building at the IBTC in Lowestoft. His
          early career began in Amsterdam, working across a number of boatyards
          before establishing his own company specialising in the construction
          and restoration of classic yachts.
        </p>
        <p>
          Since 2007, Anne has been based in North London, focusing on bespoke
          interior joinery and architectural woodworking. His work ranges from
          custom-designed furniture to fully tailored kitchens, bedroom
          furniture, bathroom cabinetry and fitted interiors — all created for
          clients seeking craftsmanship, longevity and timeless design.
        </p>
        <p>
          With a deep appreciation for carefully selected materials, Anne
          combines traditional joinery techniques with refined hand-finishing to
          create bespoke pieces that feel timeless, functional, and made to be
          enjoyed for generations.
        </p>
      </div>
      <div class="sig"><span class="nm">Anne van Mansvelt</span></div>
    </div>
  </section>

  <!-- ===================== CONTACT / INSTAGRAM ===================== -->
  <section class="contact" id="contact">
    <div class="contact-in shell pad">
      <div class="reveal">
        <span class="eyebrow">See the latest work</span>
        <h2>It all lives on <em>Instagram.</em></h2>
        <p class="lede">
          New pieces are posted as they leave the workshop. Scan the code to
          follow along — or get in touch to start a commission of your own.
        </p>
        <div class="lines">
          <a href={igUrl} target="_blank" rel="noopener">
            <span class="lab">Instagram</span><span class="val">@{site.instagramHandle}</span>
          </a>
          <a href={`mailto:${site.email}`}>
            <span class="lab">Email</span><span class="val">{site.email}</span>
          </a>
          <a href={`tel:${site.phoneIntl}`}>
            <span class="lab">Telephone</span><span class="val">{site.phone}</span>
          </a>
          <div>
            <span class="lab">Workshop</span><span class="val">{site.workshopLocation}</span>
          </div>
        </div>
      </div>

      <a class="qr-card reveal" href={igUrl} target="_blank" rel="noopener">
        <div class="qr-top">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
          <span>Follow on Instagram</span>
        </div>
        <Image class="qrimg" src={qr} alt={`Instagram QR code for @${site.instagramHandle}`} widths={[320, 640]} />
        <div class="handle">@{site.instagramHandle}</div>
        <div class="hint">Point your camera at the code</div>
      </a>
    </div>
  </section>
</BaseLayout>
