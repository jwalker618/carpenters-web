---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Only offer filters for categories that actually have projects.
const categories = [...new Set(projects.map((p) => p.data.category))].sort();
---

<BaseLayout title="Portfolio">
  <section class="mx-auto max-w-6xl px-5 py-16">
    <h1 class="font-serif text-4xl italic sm:text-5xl">Portfolio.</h1>
    <p class="mt-2 max-w-xl text-bark-soft">
      Every piece is made to order. Browse the full collection below.
    </p>

    <!-- Category filter -->
    <div class="mt-8 flex flex-wrap gap-2" id="filters">
      <button
        class="filter-btn border border-forest bg-forest px-4 py-1.5 text-xs tracking-widest text-cream uppercase"
        data-category="all">All</button
      >
      {
        categories.map((cat) => (
          <button
            class="filter-btn border border-cream-deep px-4 py-1.5 text-xs tracking-widest text-bark-soft uppercase transition-colors hover:border-forest"
            data-category={cat}
          >
            {cat}
          </button>
        ))
      }
    </div>

    <div
      class="mt-10 grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3"
      id="project-grid"
    >
      {
        projects.map((project) => (
          <div class="project-item" data-category={project.data.category}>
            <ProjectCard project={project} />
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.project-item');
  const active = ['border-forest', 'bg-forest', 'text-cream'];
  const idle = ['border-cream-deep', 'text-bark-soft'];

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;
      buttons.forEach((b) => {
        b.classList.remove(...active);
        b.classList.add(...idle);
      });
      btn.classList.remove(...idle);
      btn.classList.add(...active);
      items.forEach((item) => {
        const show = category === 'all' || item.dataset.category === category;
        item.classList.toggle('hidden', !show);
      });
    });
  });
</script>
