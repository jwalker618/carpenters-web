---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Gallery from '../../components/Gallery.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const formattedDate = data.date.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={data.title} description={data.description}>
  <article class="mx-auto max-w-5xl px-5 py-12">
    <a
      href="/portfolio"
      class="text-xs tracking-widest text-bark-soft uppercase hover:text-forest"
      >&larr; All work</a
    >

    <header class="mt-6">
      <p class="text-xs tracking-widest text-forest uppercase">
        {data.category}
      </p>
      <h1 class="mt-1 font-serif text-4xl sm:text-5xl">{data.title}</h1>
    </header>

    <!-- Cover image -->
    <div class="mt-8 overflow-hidden bg-cream-deep">
      <Image
        src={data.coverImage}
        alt={data.title}
        widths={[768, 1280, 1600]}
        sizes="(max-width: 1024px) 100vw, 1024px"
        class="w-full object-cover"
        loading="eager"
      />
    </div>

    <div class="mt-10 grid gap-10 md:grid-cols-[1fr_240px]">
      <!-- Long-form description (from the markdown body) -->
      <div
        class="space-y-4 text-lg leading-relaxed text-bark-soft [&_p]:mb-4"
      >
        <Content />
      </div>

      <!-- Details sidebar -->
      <aside class="space-y-6 text-sm md:border-l md:border-cream-deep md:pl-8">
        <div>
          <h2 class="text-xs tracking-widest text-bark-soft uppercase">
            Completed
          </h2>
          <p class="mt-1 font-serif text-xl">{formattedDate}</p>
        </div>
        <div>
          <h2 class="text-xs tracking-widest text-bark-soft uppercase">
            Materials
          </h2>
          <ul class="mt-1 space-y-0.5">
            {data.materials.map((m) => <li>{m}</li>)}
          </ul>
        </div>
      </aside>
    </div>

    <!-- Photo gallery with lightbox -->
    {
      data.gallery.length > 0 && (
        <section class="mt-14">
          <h2 class="mb-5 font-serif text-2xl">Gallery</h2>
          <Gallery images={data.gallery} title={data.title} />
        </section>
      )
    }

    <!-- Optional client testimonial -->
    {
      data.testimonial?.quote && (
        <blockquote class="mt-14 border-l-2 border-forest pl-6">
          <p class="font-serif text-2xl leading-snug text-bark">
            &ldquo;{data.testimonial.quote}&rdquo;
          </p>
          <footer class="mt-3 text-sm tracking-wide text-bark-soft uppercase">
            — {data.testimonial.attribution}
          </footer>
        </blockquote>
      )
    }

    <div class="mt-16 border-t border-cream-deep pt-8">
      <a
        href="/contact"
        class="text-sm tracking-widest text-forest uppercase hover:underline"
        >Commission something like this &rarr;</a
      >
    </div>
  </article>
</BaseLayout>
